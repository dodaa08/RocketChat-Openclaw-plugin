{
  "name": "openclaw-rocketchat-webhook",
  "version": "0.6.0",
  "description": "Rocket.Chat OpenClaw channel: REST chat.sendMessage (single index.ts)",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "channel": {
      "id": "rocketchat-webhook",
      "label": "Rocket.Chat (webhook)",
      "selectionLabel": "Rocket.Chat (webhook)",
      "docsPath": "/channels/rocketchat-webhook",
      "blurb": "REST outbound to Rocket.Chat (chat.sendMessage).",
      "order": 71,
      "aliases": ["rc-hook", "rocketchat-hook"]
    }
  },
  "keywords": ["openclaw", "openclaw-plugin", "rocketchat", "webhook", "hooks"],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "files": ["dist/", "openclaw.plugin.json"]
}
